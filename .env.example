ENVIRONMENT=development
SECRET_KEY=replace-with-a-secure-secret
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=http://localhost:8000
DATABASE_URL=sqlite:///db.sqlite3

# Required in production. In development, fill all five R2 variables to upload
# to R2; leave them empty to store uploads in the local media/ directory.
# Create an R2 API token with Object Read & Write permission for this bucket.
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_ENDPOINT_URL=https://ACCOUNT_ID.r2.cloudflarestorage.com

# Public R2 development URL or a custom domain, without a trailing slash.
R2_PUBLIC_URL=https://pub-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.r2.dev

# Optional override; defaults to R2_PUBLIC_URL in production.
THUMBNAIL_URL=
